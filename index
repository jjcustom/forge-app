  {wk:1,phase:"No running",s:[{t:"Walk",d:"20 min",n:"Easy treadmill incline walk — protect the knee"},{t:"Assault Bike",d:"20 min",n:"Low resistance, easy pace"},{t:"Row",d:"5,000m",n:"Steady state Concept 2"}]},
  {wk:2,phase:"No running",s:[{t:"Walk",d:"25 min",n:"Brisk walk, slight incline"},{t:"Assault Bike",d:"25 min",n:"Moderate pace"},{t:"Row",d:"6,000m",n:"Push the pace slightly"}]},
  {wk:3,phase:"Walk/Run begins",s:[{t:"Walk/Run",d:"20 min",n:"2 min run / 1 min walk × 6 rounds"},{t:"Assault Bike",d:"25 min",n:"Steady state"},{t:"Row",d:"5,000m",n:"Steady + 10 min walk/run after"}]},
  {wk:4,phase:"Walk/Run extends",s:[{t:"Walk/Run",d:"25 min",n:"3 min run / 1 min walk × 6 rounds"},{t:"Easy Run",d:"15 min",n:"First continuous run — flat surface only"},{t:"Long Walk/Run",d:"35 min",n:"4 min run / 1 min walk"}]},
  {wk:5,phase:"Continuous running",s:[{t:"Easy Run",d:"2 mi",n:"Conversational pace"},{t:"Tempo",d:"15 min",n:"Comfortably hard"},{t:"Long Run",d:"3 mi",n:"Easy pace — time on feet"}]},
  {wk:6,phase:"Building mileage",s:[{t:"Easy Run",d:"2.5 mi",n:""},{t:"Intervals",d:"3×800m",n:"400m jog recovery"},{t:"Long Run",d:"4 mi",n:""}]},
  {wk:7,phase:"Half marathon prep",s:[{t:"Easy Run",d:"3 mi",n:""},{t:"Tempo",d:"25 min",n:"Sustained hard effort"},{t:"Long Run",d:"5 mi",n:"Slowest comfortable pace"}]},
  {wk:8,phase:"Peak shred",s:[{t:"Easy Run",d:"3 mi",n:""},{t:"Intervals",d:"4×1K",n:"2 min recovery jogs"},{t:"Long Run",d:"6 mi",n:"Half marathon foundation"}]},
];

const REHAB=[
  {n:"Terminal knee extension (TKE)",s:"3×15",side:"Both",note:"Band behind knee — VMO activation"},
  {n:"Straight leg raise (SLR)",s:"3×15",side:"Both",note:"Hold 2 sec at top"},
  {n:"Clamshell (band)",s:"3×20",side:"Both",note:"Hip abduction — glute med"},
  {n:"Glute bridge",s:"3×15",side:"Both",note:"Progress to single-leg after week 4"},
  {n:"VMO quad set",s:"3×20",side:"Both",note:"Seated, tighten quad, hold 5 sec"},
  {n:"Ankle pump + circles",s:"2×20",side:"Both",note:"Circulation — especially left knee"},
  {n:"Standing hip abduction (band)",s:"3×15",side:"Both",note:"Lateral raise with band"},
  {n:"Heel slide",s:"3×15",side:"Left only",note:"Gentle knee flexion — ROM recovery"},
];

let ST={wt:215,wtLog:[],wd:{},rehab:{},groc:{},notes:[],wk:1,plThr:3,plSens:'lenient',saunaOn:false,saunaS:0,saunaInt:null};
function save(){try{localStorage.setItem('fv7',JSON.stringify(ST));}catch(e){}}
function load(){try{const d=localStorage.getItem('fv7');if(d)ST={...ST,...JSON.parse(d)};}catch(e){}}
load();

function injectD1(){
  let ch=false;
  for(const[k,sets] of Object.entries(D1)){
    const[day,exName]=k.split('__');
    const hk=`${day}__${exName}`;
    if(!ST.wd[hk]){
      let bw=0,br=0;
      sets.forEach((s,i)=>{
        const sk=`1__${day}__${exName}__s${i+1}`;
        if(!ST.wd[sk]){ST.wd[sk]={wt:s.wt,reps:s.reps};ch=true;}
        if(parseFloat(s.wt)>bw)bw=parseFloat(s.wt);
        if(parseInt(s.reps)>br)br=parseInt(s.reps);
      });
      ST.wd[hk]=[{bestWeight:bw,bestReps:br,week:1,date:"4/8/2026"}];ch=true;
    }
  }
  if(!ST.wd['done__1__Monday']){ST.wd['done__1__Monday']=true;ch=true;}
  if(ch)save();
}
injectD1();

function showTab(t){
  document.querySelectorAll('.tab-btn').forEach(b=>b.classList.toggle('active',b.getAttribute('onclick').includes("'"+t+"'")));
  document.querySelectorAll('.section').forEach(s=>s.classList.remove('active'));
  document.getElementById('tab-'+t).classList.add('active');
  if(t==='str')renderStr();if(t==='meals')renderMeals();if(t==='groc')renderGroc();
  if(t==='run')renderRun();if(t==='rehab')renderRehab();if(t==='dash')renderDash();
}

function logWt(){
  const v=parseFloat(document.getElementById('wi').value);if(!v||v<100||v>400)return;
  ST.wt=v;ST.wtLog.unshift({date:new Date().toLocaleDateString('en-US',{month:'short',day:'numeric'}),wt:v});
  if(ST.wtLog.length>14)ST.wtLog.pop();save();renderDash();
}

function renderDash(){
  const w=ST.wt,lost=Math.max(0,215-w).toFixed(1),pct=Math.min(100,Math.max(0,((215-w)/20)*100));
  document.getElementById('dw').textContent=w;document.getElementById('dl').textContent=lost;
  document.getElementById('nav-wt').textContent=w+' lbs';document.getElementById('wp').style.width=pct+'%';
  document.getElementById('dp').textContent=countPlat();
  const h=document.getElementById('wh');
  if(!ST.wtLog.length){h.innerHTML='<div style="font-size:11px;color:var(--text3);text-align:center;padding:8px">No weight logs yet</div>';return;}
  h.innerHTML=ST.wtLog.map((e,i)=>{
    const prev=ST.wtLog[i+1];let ch='';
    if(prev){const d=(e.wt-prev.wt).toFixed(1);const cl=d<0?'up':d>0?'dn':'nc';const lb=d<0?d+' lbs':d>0?'+'+d+' lbs':'—';ch=`<span class="hch ${cl}">${lb}</span>`;}
    return `<div class="hist-item"><span class="hdate">${e.date}</span><span class="hval">${e.wt} lbs</span>${ch}</div>`;
  }).join('');
  renderPlatSum();
}

function countPlat(){let c=0;PH.forEach(ph=>ph.days.forEach(d=>d.exercises.forEach(ex=>{if(isPlat(ex.n,d.day))c++;})));return c;}

function renderPlatSum(){
  const list=[];PH.forEach(ph=>ph.days.forEach(d=>d.exercises.forEach(ex=>{if(isPlat(ex.n,d.day))list.push({n:ex.n,day:d.day,m:ex.m});})));
  const el=document.getElementById('psumm');
  if(!list.length){el.innerHTML='<div style="font-size:11px;color:var(--green);padding:6px 0">No plateaus — keep pushing!</div>';return;}
  el.innerHTML=list.map(p=>{const tag=p.m&&MTAGS[p.m]?`<span class="mtag ${MTAGS[p.m]}">${MLBLS[p.m]}</span>`:'';return `<div style="display:flex;justify-content:space-between;align-items:center;padding:6px 0;border-bottom:1px solid var(--border);font-size:11px"><span style="color:var(--amber)">${p.n} ${tag}</span><span style="color:var(--text3)">${p.day}</span></div>`;}).join('');
}

function exk(n,d){return `${d}__${n}`;}
function exHist(n,d){return ST.wd[exk(n,d)]||[];}
function isPlat(n,day){
  const h=exHist(n,day);if(h.length<ST.plThr)return false;
  const r=h.slice(0,ST.plThr);const mw=Math.max(...r.map(s=>parseFloat(s.bestWeight)||0));const mr=Math.max(...r.map(s=>parseInt(s.bestReps)||0));
  const fw=parseFloat(r[r.length-1].bestWeight)||0;const fr=parseInt(r[r.length-1].bestReps)||0;
  return ST.plSens==='strict'?(mw<=fw||mr<=fr):(mw<=fw&&mr<=fr);
}

function phFor(w){for(const p of PH)if(p.weeks.includes(w))return p;return PH[0];}

function renderStr(){
  document.getElementById('pwd').textContent=ST.plThr;
  const pills=document.getElementById('spills');pills.innerHTML='';
  for(let i=1;i<=8;i++){const b=document.createElement('button');b.className='week-pill'+(i===ST.wk?' active':'');b.textContent='Week '+i;const wi=i;b.onclick=()=>{ST.wk=wi;save();renderStr();};pills.appendChild(b);}
  const ph=phFor(ST.wk);const cont=document.getElementById('scont');
  cont.innerHTML=`<div class="phase-badge" style="background:${ph.color}22;border:1px solid ${ph.color}55;color:${ph.color}">${ph.label} — Week ${ST.wk}</div>`;
  for(const day of ph.days){
    const wc=document.createElement('div');wc.className='workout-card';
    const dk=`done__${ST.wk}__${day.day}`;const done=ST.wd[dk];
    wc.innerHTML=`<div class="workout-header"><div><div class="workout-day-lbl">${day.day}</div><div class="workout-name">${day.name}</div></div><button class="btn-done${done?' completed':''}" onclick="togDone('${dk}',this)">${done?'✓ Done':'Mark done'}</button></div>`;
    for(const ex of day.exercises){
      const plat=isPlat(ex.n,day.day);const isF=ex.m&&ex.m!=='compound';
      const isD1=ST.wk===1&&day.day==='Monday'&&D1[`Monday__${ex.n}`];
      const hist=exHist(ex.n,day.day);const last=hist[0]||{};
      const div=document.createElement('div');div.className='ex-row'+(plat?' plateau':isD1?' day1-logged':isF?' focus-muscle':'');
      const mt=ex.m&&MTAGS[ex.m]?`<span class="mtag ${MTAGS[ex.m]}">${MLBLS[ex.m]}</span>`:'';
      const ni=ex.note?`<div class="ex-note">${ex.note}</div>`:'';
      let top=`<div class="ex-top"><div><div class="ex-name">${ex.n}${isD1?'<span style="font-size:9px;color:var(--green);margin-left:5px">✓ Apr 8</span>':''}</div><div class="ex-meta">${ex.sets}×${ex.reps} · ${ex.eq}</div>${mt}${ni}</div>`;
      if(plat)top+=`<div class="plateau-tag"><div class="pdot"></div>PLATEAU</div>`;
      top+='</div>';
      const ns=typeof ex.sets==='number'?ex.sets:1;
      let sr='<div class="sets-row">';
      for(let s=1;s<=ns;s++){
        const sk=`${ST.wk}__${day.day}__${ex.n}__s${s}`;const sv=ST.wd[sk]||{};
        const pw=last[`s${s}_wt`]||'';const pr=last[`s${s}_reps`]||'';
        const wi=sv.wt&&pw&&parseFloat(sv.wt)>parseFloat(pw);const ri=sv.reps&&pr&&parseInt(sv.reps)>parseInt(pr);
        const id1=isD1&&D1[`Monday__${ex.n}`]&&D1[`Monday__${ex.n}`][s-1];
        sr+=`<div class="set-box"><div class="set-lbl">Set ${s}</div><div class="set-inputs"><div><input class="si${wi?' improved':id1?' d1':''}" type="number" placeholder="lbs" value="${sv.wt||''}" onchange="logSet('${sk}','wt',this.value,'${ex.n}','${day.day}','${s}')" style="width:50px"><div class="si-lbl">wt</div></div><div><input class="si${ri?' improved':id1?' d1':''}" type="number" placeholder="reps" value="${sv.reps||''}" onchange="logSet('${sk}','reps',this.value,'${ex.n}','${day.day}','${s}')" style="width:50px"><div class="si-lbl">reps</div></div></div></div>`;
      }
      sr+='</div>';div.innerHTML=top+sr;wc.appendChild(div);
    }
    cont.appendChild(wc);
  }
}

function logSet(sk,f,v,n,day,s){
  if(!ST.wd[sk])ST.wd[sk]={};ST.wd[sk][f]=v;
  updHist(n,day,ST.wk);save();setTimeout(()=>renderStr(),50);renderDash();
}

function updHist(n,day,wk){
  const k=exk(n,day);const ph=phFor(wk);const dd=ph.days.find(d=>d.day===day);if(!dd)return;
  const ex=dd.exercises.find(e=>e.n===n);if(!ex)return;
  let bw=0,br=0;const sd={};const ns=typeof ex.sets==='number'?ex.sets:1;
  for(let s=1;s<=ns;s++){const sk=`${wk}__${day}__${n}__s${s}`;const sv=ST.wd[sk]||{};
    if(sv.wt)sd[`s${s}_wt`]=sv.wt;if(sv.reps)sd[`s${s}_reps`]=sv.reps;
    if(parseFloat(sv.wt)>bw)bw=parseFloat(sv.wt);if(parseInt(sv.reps)>br)br=parseInt(sv.reps);}
  sd.bestWeight=bw;sd.bestReps=br;sd.week=wk;sd.date=new Date().toLocaleDateString();
  if(!ST.wd[k])ST.wd[k]=[];
  const ei=ST.wd[k].findIndex(h=>h.week===wk);
  if(ei>=0)ST.wd[k][ei]=sd;else ST.wd[k].unshift(sd);
  if(ST.wd[k].length>8)ST.wd[k].pop();
}

function togDone(k,btn){ST.wd[k]=!ST.wd[k];btn.textContent=ST.wd[k]?'✓ Done':'Mark done';btn.className='btn-done'+(ST.wd[k]?' completed':'');save();}

function renderMeals(){
  const el=document.getElementById('macc');el.innerHTML='';
  MEALS.forEach((day,i)=>{
    const open=i===0;
    const tl=day.type==='training'?'Training':day.type==='cardio'?'Cardio':day.type==='long-run'?'Long run':'Rest day';
    const mp=`<span style="background:rgba(59,130,246,0.12);color:#60a5fa;padding:2px 6px;border-radius:5px;font-size:10px">P${day.p}</span><span style="background:rgba(34,197,94,0.1);color:#4ade80;padding:2px 6px;border-radius:5px;font-size:10px">C${day.c}</span><span style="background:rgba(245,158,11,0.12);color:#fbbf24;padding:2px 6px;border-radius:5px;font-size:10px">F${day.f}</span>`;
    const acc=document.createElement('div');acc.className='day-acc';
    acc.innerHTML=`<div class="day-hdr" onclick="togDay(${i})"><div style="display:flex;align-items:center"><div class="day-dot" style="background:${day.color}"></div><div><div class="day-name">${day.day}</div><div class="day-cal">${day.cal.toLocaleString()} cal · ${tl}</div></div></div><div style="display:flex;align-items:center;gap:6px"><div style="display:flex;gap:3px">${mp}</div><div class="day-chev${open?' open':''}" id="chv${i}">▼</div></div></div><div class="day-body${open?' open':''}" id="db${i}"></div>`;
    el.appendChild(acc);buildDayBody(day,i);
  });
}

function buildDayBody(day,i){
  const b=document.getElementById('db'+i);if(!b)return;
  let h='';
  day.meals.forEach(m=>{
    const pk=m.pk?`<div class="pk-tag">🌿 ${m.pk}</div>`:'';
    h+=`<div class="meal-row"><div class="meal-time-lbl">${m.t}</div><div class="meal-food-txt">${m.f}</div>${pk}<div class="meal-mac"><span class="mm" style="color:var(--blue)">${m.cal} cal</span><span class="mm">P ${m.p}g</span><span class="mm">C ${m.c}g</span><span class="mm">F ${m.fa}g</span></div></div>`;
  });
  const tot=day.meals.reduce((a,m)=>({cal:a.cal+m.cal,p:a.p+m.p,c:a.c+m.c,f:a.f+m.fa}),{cal:0,p:0,c:0,f:0});
  h+=`<div class="day-totals"><div class="dt-item"><div class="dt-val" style="color:var(--blue)">${tot.cal}</div><div class="dt-lbl">Calories</div></div><div class="dt-item"><div class="dt-val" style="color:#60a5fa">${tot.p}g</div><div class="dt-lbl">Protein</div></div><div class="dt-item"><div class="dt-val" style="color:#4ade80">${tot.c}g</div><div class="dt-lbl">Carbs</div></div><div class="dt-item"><div class="dt-val" style="color:#fbbf24">${tot.f}g</div><div class="dt-lbl">Fat</div></div></div>`;
  b.innerHTML=h;
}

function togDay(i){const b=document.getElementById('db'+i);const c=document.getElementById('chv'+i);const o=b.classList.contains('open');b.classList.toggle('open',!o);c.classList.toggle('open',!o);}
function toggleAll(open){MEALS.forEach((_,i)=>{const b=document.getElementById('db'+i);const c=document.getElementById('chv'+i);if(b)b.classList.toggle('open',open);if(c)c.classList.toggle('open',open);});}

function renderGroc(){
  const el=document.getElementById('glist');el.innerHTML='';let total=0,checked=0;
  for(const[cat,items] of Object.entries(GROC)){
    const sec=document.createElement('div');sec.className='groc-section';
    sec.innerHTML=`<div class="groc-sec-title">${cat}</div>`;
    items.forEach(item=>{
      const k='g__'+item.n;const ck=ST.groc[k]||false;total++;if(ck)checked++;
      const row=document.createElement('div');row.className='groc-item';
      row.innerHTML=`<div class="groc-chk${ck?' on':''}" onclick="togG('${k}',this)"></div><span class="groc-name${ck?' bought':''}">${item.n}</span><span class="groc-qty">${item.q}</span>`;
      sec.appendChild(row);
    });
    el.appendChild(sec);
  }
  document.getElementById('gc').textContent=checked;document.getElementById('gt').textContent=total;
}

function togG(k,el){ST.groc[k]=!ST.groc[k];el.classList.toggle('on',ST.groc[k]);const nm=el.nextElementSibling;if(nm)nm.classList.toggle('bought',ST.groc[k]);save();updGrocCount();}
function updGrocCount(){let tot=0,ck=0;for(const[,items] of Object.entries(GROC))items.forEach(i=>{tot++;if(ST.groc['g__'+i.n])ck++;});document.getElementById('gc').textContent=ck;document.getElementById('gt').textContent=tot;}
function clearGroc(){if(confirm('Clear all grocery checks?')){ST.groc={};save();renderGroc();}}

function renderRun(){
  const el=document.getElementById('rcont');el.innerHTML='';
  const tc={Walk:'#22c55e','Assault Bike':'#3b82f6',Row:'#6366f1','Walk/Run':'#f59e0b','Easy Run':'#3b82f6',Tempo:'#f59e0b',Intervals:'#ef4444','Long Run':'#22c55e','Long Walk/Run':'#f59e0b'};
  for(const wk of RUNS){
    const card=document.createElement('div');card.className='card';card.style.marginBottom='10px';
    card.innerHTML=`<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px"><span style="font-weight:600;font-size:13px">Week ${wk.wk}</span><span style="font-size:10px;color:var(--text3)">${wk.phase}</span></div>`;
    for(const s of wk.s){
      const c=tc[s.t]||'#888';const rid=`r${wk.wk}_${s.t.replace(/\s/g,'_')}`;
      const rc=document.createElement('div');rc.style.cssText='background:var(--surface2);border-radius:10px;padding:12px;margin-bottom:8px';
      rc.innerHTML=`<div style="font-size:10px;font-weight:600;text-transform:uppercase;color:${c};margin-bottom:2px">${s.t}</div><div style="font-size:20px;font-weight:700;margin-bottom:${s.n?4:8}px">${s.d}</div>${s.n?`<div style="font-size:11px;color:var(--text3);margin-bottom:8px">${s.n}</div>`:''}<div style="display:flex;gap:8px;align-items:center"><div style="font-size:22px;font-weight:700;color:var(--blue);flex:1;font-variant-numeric:tabular-nums" id="td_${rid}">00:00</div><button style="background:var(--blue);border:none;border-radius:8px;color:#fff;font-size:11px;font-family:inherit;padding:7px 12px;cursor:pointer;font-weight:600" id="tb_${rid}" onclick="togRun('${rid}')">Start</button><button style="background:transparent;border:1px solid var(--border2);border-radius:8px;color:var(--text2);font-size:11px;font-family:inherit;padding:7px 12px;cursor:pointer" onclick="rstRun('${rid}')">Reset</button></div>`;
      card.appendChild(rc);
    }
    el.appendChild(card);
  }
}

const RT={};
function togRun(id){const d=document.getElementById('td_'+id);const b=document.getElementById('tb_'+id);if(!RT[id])RT[id]={on:false,s:0,iv:null};const t=RT[id];if(t.on){clearInterval(t.iv);t.on=false;b.textContent='Resume';b.style.background='var(--blue)';}else{t.on=true;b.textContent='Stop';b.style.background='var(--red)';t.iv=setInterval(()=>{t.s++;const m=Math.floor(t.s/60).toString().padStart(2,'0');const s=(t.s%60).toString().padStart(2,'0');d.textContent=m+':'+s;},1000);}}
function rstRun(id){if(RT[id]){clearInterval(RT[id].iv);RT[id]={on:false,s:0,iv:null};}const d=document.getElementById('td_'+id);const b=document.getElementById('tb_'+id);if(d)d.textContent='00:00';if(b){b.textContent='Start';b.style.background='var(--blue)';}}

function renderRehab(){
  const el=document.getElementById('rlist');el.innerHTML='';const today=new Date().toDateString();
  REHAB.forEach((r,i)=>{const k=`rh_${today}_${i}`;const ck=ST.rehab[k];const div=document.createElement('div');div.className='rehab-item';div.innerHTML=`<div class="rehab-info"><div class="rehab-name">${r.n}</div><div class="rehab-detail">${r.s} · ${r.side} · ${r.note}</div></div><button class="chk-btn${ck?' checked':''}" onclick="togR('${k}',this)"></button>`;el.appendChild(div);});
  if(ST.notes&&ST.notes.length)document.getElementById('rnotes').value=ST.notes[0]||'';
}
function togR(k,b){ST.rehab[k]=!ST.rehab[k];b.className='chk-btn'+(ST.rehab[k]?' checked':'');save();}
function saveNotes(){const v=document.getElementById('rnotes').value;if(!ST.notes)ST.notes=[];ST.notes.unshift(v);if(ST.notes.length>10)ST.notes.pop();save();const b=document.querySelector('#tab-rehab .btn-primary');b.textContent='Saved!';setTimeout(()=>b.textContent='Save note',1500);}

function toggleSauna(){const b=document.getElementById('sb');if(!ST.saunaOn){ST.saunaOn=true;b.textContent='Stop';b.className='tbtn stop';ST.saunaInt=setInterval(()=>{ST.saunaS++;const m=Math.floor(ST.saunaS/60).toString().padStart(2,'0');const s=(ST.saunaS%60).toString().padStart(2,'0');document.getElementById('st').textContent=m+':'+s;},1000);}else{clearInterval(ST.saunaInt);ST.saunaOn=false;b.textContent='Resume';b.className='tbtn start';}}
function resetSauna(){clearInterval(ST.saunaInt);ST.saunaOn=false;ST.saunaS=0;document.getElementById('st').textContent='00:00';document.getElementById('sb').textContent='Start';document.getElementById('sb').className='tbtn start';}

function updPlat(){ST.plThr=parseInt(document.getElementById('pt').value);ST.plSens=document.getElementById('ps').value;document.getElementById('pwd').textContent=ST.plThr;save();renderDash();}
function resetAll(){if(confirm('Reset ALL data? Day 1 will be re-injected.')){ST={wt:215,wtLog:[],wd:{},rehab:{},groc:{},notes:[],wk:1,plThr:3,plSens:'lenient',saunaOn:false,saunaS:0,saunaInt:null};save();injectD1();location.reload();}}

renderDash();
</script>
