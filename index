<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>FORGE Tracker</title>
<style>
:root{--bg:#0a0a0b;--surface:#111113;--surface2:#1a1a1e;--surface3:#222228;--border:rgba(255,255,255,0.07);--border2:rgba(255,255,255,0.12);--text:#f0f0f0;--text2:#888;--text3:#555;--blue:#3b82f6;--blue-dim:rgba(59,130,246,0.15);--green:#22c55e;--green-dim:rgba(34,197,94,0.12);--amber:#f59e0b;--amber-dim:rgba(245,158,11,0.12);--red:#ef4444;--red-dim:rgba(239,68,68,0.12);--orange:#f97316;--orange-dim:rgba(249,115,22,0.12);--purple:#a855f7;--purple-dim:rgba(168,85,247,0.12);--plateau:rgba(245,158,11,0.18);--plateau-border:rgba(245,158,11,0.5)}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
body{font-family:-apple-system,BlinkMacSystemFont,'SF Pro Display',sans-serif;background:var(--bg);color:var(--text);min-height:100vh}
.nav{display:flex;align-items:center;justify-content:space-between;padding:14px 18px 10px;border-bottom:1px solid var(--border);position:sticky;top:0;background:var(--bg);z-index:100}
.nav-logo{font-size:20px;font-weight:700;letter-spacing:-0.5px;color:var(--blue)}
.nav-sub{font-size:10px;color:var(--text3);letter-spacing:1px;text-transform:uppercase}
.tabs{display:flex;gap:2px;padding:10px 14px 0;overflow-x:auto;scrollbar-width:none}
.tabs::-webkit-scrollbar{display:none}
.tab-btn{flex-shrink:0;padding:7px 13px;border:1px solid var(--border);border-radius:20px;background:transparent;color:var(--text2);font-size:11px;font-family:inherit;cursor:pointer;transition:all 0.2s;white-space:nowrap}
.tab-btn.active{background:var(--blue);border-color:var(--blue);color:#fff;font-weight:600}
.section{display:none;padding:14px}.section.active{display:block}
.card{background:var(--surface);border:1px solid var(--border);border-radius:14px;padding:14px;margin-bottom:10px}
.card-title{font-size:11px;font-weight:600;color:var(--text2);text-transform:uppercase;letter-spacing:0.8px;margin-bottom:10px}
.metrics{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin-bottom:12px}
.metric{background:var(--surface2);border-radius:10px;padding:10px 8px;text-align:center}
.metric-val{font-size:19px;font-weight:700;margin-bottom:2px}
.metric-label{font-size:9px;color:var(--text3);text-transform:uppercase;letter-spacing:0.5px}
.row-input{display:flex;gap:8px;align-items:center;margin-bottom:10px}
.row-input input{flex:1;background:var(--surface2);border:1px solid var(--border2);border-radius:10px;padding:9px 12px;color:var(--text);font-size:15px;font-family:inherit}
.btn-primary{background:var(--blue);border:none;border-radius:10px;color:#fff;font-size:12px;font-weight:600;font-family:inherit;padding:9px 16px;cursor:pointer;white-space:nowrap}
.btn-sm{background:transparent;border:1px solid var(--border2);border-radius:8px;color:var(--text2);font-size:11px;font-family:inherit;padding:6px 12px;cursor:pointer}
.prog-track{height:7px;background:var(--surface3);border-radius:4px;overflow:hidden;margin:4px 0}
.prog-fill{height:100%;border-radius:4px;transition:width 0.5s ease}
.prog-labels{display:flex;justify-content:space-between;font-size:10px;color:var(--text3);margin-top:3px}
.week-pills{display:flex;flex-wrap:wrap;gap:5px;margin-bottom:12px}
.week-pill{padding:5px 11px;border:1px solid var(--border);border-radius:20px;font-size:11px;color:var(--text2);cursor:pointer;background:transparent;font-family:inherit}
.week-pill.active{background:var(--blue-dim);border-color:var(--blue);color:var(--blue)}
.phase-badge{display:inline-block;padding:4px 12px;border-radius:20px;font-size:11px;font-weight:600;margin-bottom:12px}
.workout-card{background:var(--surface);border:1px solid var(--border);border-radius:14px;margin-bottom:10px;overflow:hidden}
.workout-header{display:flex;justify-content:space-between;align-items:center;padding:12px 14px;border-bottom:1px solid var(--border)}
.workout-day-lbl{font-size:10px;font-weight:600;color:var(--blue);text-transform:uppercase;letter-spacing:0.8px}
.workout-name{font-size:14px;font-weight:600;margin-top:2px}
.btn-done{border:1px solid var(--border2);border-radius:8px;background:transparent;color:var(--text2);font-size:11px;font-family:inherit;padding:5px 11px;cursor:pointer}
.btn-done.completed{background:var(--green-dim);border-color:var(--green);color:var(--green)}
.ex-row{padding:10px 14px;border-bottom:1px solid var(--border)}
.ex-row:last-child{border-bottom:none}
.ex-row.plateau{background:var(--plateau);border-left:3px solid var(--amber)}
.ex-row.focus-muscle{border-left:3px solid var(--purple)}
.ex-row.day1-logged{border-left:3px solid var(--green)}
.ex-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:7px}
.ex-name{font-size:13px;font-weight:500;flex:1}
.ex-meta{font-size:10px;color:var(--text3);margin-top:2px}
.ex-note{font-size:10px;color:var(--text3);margin-top:2px;font-style:italic}
.mtag{display:inline-block;padding:2px 6px;border-radius:5px;font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;margin-right:3px;margin-top:3px}
.ts{background:rgba(168,85,247,0.15);color:#c084fc;border:1px solid rgba(168,85,247,0.3)}
.tt{background:rgba(239,68,68,0.12);color:#f87171;border:1px solid rgba(239,68,68,0.25)}
.tb{background:rgba(59,130,246,0.15);color:#60a5fa;border:1px solid rgba(59,130,246,0.3)}
.tc{background:rgba(34,197,94,0.1);color:#4ade80;border:1px solid rgba(34,197,94,0.2)}
.plateau-tag{display:flex;align-items:center;gap:3px;background:var(--amber-dim);border:1px solid var(--plateau-border);border-radius:6px;padding:3px 7px;font-size:9px;color:var(--amber);font-weight:600;white-space:nowrap;margin-left:6px;flex-shrink:0}
.pdot{width:5px;height:5px;border-radius:50%;background:var(--amber);animation:pulse 1.5s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:0.3}}
.sets-row{display:flex;gap:5px;flex-wrap:wrap}
.set-box{display:flex;flex-direction:column;align-items:center;gap:2px}
.set-lbl{font-size:9px;color:var(--text3);text-transform:uppercase;letter-spacing:0.5px}
.set-inputs{display:flex;gap:3px}
.si{width:50px;background:var(--surface2);border:1px solid var(--border2);border-radius:7px;padding:6px 3px;text-align:center;font-size:12px;color:var(--text);font-family:inherit}
.si:focus{outline:none;border-color:var(--blue)}
.si.improved{border-color:var(--green);background:var(--green-dim)}
.si.d1{border-color:var(--green);background:rgba(34,197,94,0.08)}
.si-lbl{font-size:9px;color:var(--text3);text-align:center}
.watch-card{background:var(--surface2);border:1px solid rgba(59,130,246,0.25);border-radius:14px;padding:14px;margin-bottom:10px}
.watch-stats{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin-top:10px}
.ws-val{font-size:16px;font-weight:700;color:var(--blue);text-align:center}
.ws-lbl{font-size:9px;color:var(--text3);text-transform:uppercase;text-align:center;margin-top:1px}
.day-acc{background:var(--surface);border:1px solid var(--border);border-radius:14px;margin-bottom:8px;overflow:hidden}
.day-hdr{display:flex;justify-content:space-between;align-items:center;padding:12px 14px;cursor:pointer}
.day-hdr:active{background:var(--surface2)}
.day-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;margin-right:10px}
.day-name{font-size:13px;font-weight:600}
.day-cal{font-size:11px;color:var(--text3)}
.day-chev{font-size:11px;color:var(--text3);transition:transform 0.2s;margin-left:8px}
.day-chev.open{transform:rotate(180deg)}
.day-body{display:none;border-top:1px solid var(--border)}
.day-body.open{display:block}
.meal-row{padding:10px 14px;border-bottom:1px solid var(--border)}
.meal-row:last-of-type{border-bottom:none}
.meal-time-lbl{font-size:10px;font-weight:600;color:var(--blue);text-transform:uppercase;letter-spacing:0.6px;margin-bottom:2px}
.meal-food-txt{font-size:12px;color:var(--text2);line-height:1.5;margin-bottom:4px}
.pk-tag{display:inline-flex;align-items:center;gap:4px;background:var(--orange-dim);border:1px solid rgba(249,115,22,0.3);border-radius:5px;padding:2px 8px;font-size:10px;color:var(--orange);margin-bottom:4px}
.meal-mac{display:flex;gap:8px;flex-wrap:wrap}
.mm{font-size:10px;color:var(--text3)}
.day-totals{display:flex;justify-content:space-between;padding:10px 14px;background:var(--surface2);flex-wrap:wrap;gap:6px}
.dt-item{text-align:center}
.dt-val{font-size:13px;font-weight:700}
.dt-lbl{font-size:9px;color:var(--text3);text-transform:uppercase}
.groc-section{margin-bottom:12px}
.groc-sec-title{font-size:11px;font-weight:600;color:var(--text2);text-transform:uppercase;letter-spacing:0.8px;padding:6px 0;border-bottom:1px solid var(--border);margin-bottom:6px}
.groc-item{display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:1px solid var(--border)}
.groc-item:last-child{border-bottom:none}
.groc-chk{width:22px;height:22px;border-radius:50%;border:2px solid var(--border2);background:transparent;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.groc-chk.on{background:var(--green);border-color:var(--green)}
.groc-chk.on::after{content:'✓';color:#fff;font-size:12px;font-weight:700}
.groc-name{flex:1;font-size:13px}
.groc-qty{font-size:11px;color:var(--text3);white-space:nowrap}
.bought{text-decoration:line-through;color:var(--text3)}
.rehab-item{display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid var(--border)}
.rehab-item:last-child{border-bottom:none}
.rehab-info{flex:1}
.rehab-name{font-size:13px;font-weight:500}
.rehab-detail{font-size:10px;color:var(--text3);margin-top:2px}
.chk-btn{width:26px;height:26px;border-radius:50%;border:2px solid var(--border2);background:transparent;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.chk-btn.checked{background:var(--green);border-color:var(--green)}
.chk-btn.checked::after{content:'✓';color:#fff;font-size:12px;font-weight:700}
.mbr{display:flex;gap:8px;align-items:center;margin-bottom:9px}
.mbl{font-size:11px;color:var(--text2);width:56px}
.mbt{flex:1;height:7px;background:var(--surface3);border-radius:4px;overflow:hidden}
.mbf{height:100%;border-radius:4px}
.mbv{font-size:11px;font-weight:600;width:38px;text-align:right}
.timer-row{display:flex;gap:8px;align-items:center;margin-top:10px}
.timer-disp{font-size:26px;font-weight:700;font-variant-numeric:tabular-nums;color:var(--blue);flex:1}
.tbtn{border:1px solid var(--border2);border-radius:8px;background:var(--surface2);color:var(--text);font-size:12px;font-family:inherit;padding:8px 14px;cursor:pointer}
.tbtn.start{background:var(--blue);border-color:var(--blue);color:#fff;font-weight:600}
.tbtn.stop{background:var(--red-dim);border-color:var(--red);color:var(--red)}
.sp{padding:10px 0;border-bottom:1px solid var(--border)}.sp:last-child{border-bottom:none}
.sp-name{font-size:12px;font-weight:600;color:var(--blue);margin-bottom:4px}
.sp-chips{display:flex;gap:6px;flex-wrap:wrap}
.sp-chip{font-size:10px;background:var(--surface2);border-radius:6px;padding:3px 8px;color:var(--text2)}
.alert{border-radius:10px;padding:10px 13px;font-size:12px;margin-bottom:10px;line-height:1.6}
.ab{background:var(--blue-dim);border:1px solid rgba(59,130,246,0.3);color:#93c5fd}
.ag{background:var(--green-dim);border:1px solid rgba(34,197,94,0.3);color:#86efac}
.aa{background:var(--amber-dim);border:1px solid rgba(245,158,11,0.3);color:#fcd34d}
.ao{background:var(--orange-dim);border:1px solid rgba(249,115,22,0.3);color:#fdba74}
.legend{display:flex;align-items:center;gap:8px;background:var(--amber-dim);border:1px solid var(--plateau-border);border-radius:10px;padding:9px 13px;margin-bottom:12px;font-size:11px;color:var(--amber)}
.mlegend{display:flex;flex-wrap:wrap;gap:5px;align-items:center;background:var(--purple-dim);border:1px solid rgba(168,85,247,0.3);border-radius:10px;padding:9px 13px;margin-bottom:12px}
.hist-item{display:flex;justify-content:space-between;align-items:center;padding:7px 0;border-bottom:1px solid var(--border);font-size:12px}.hist-item:last-child{border-bottom:none}
.hdate{color:var(--text3)}.hval{font-weight:600}
.hch{font-size:10px;padding:2px 6px;border-radius:5px}
.up{background:var(--green-dim);color:var(--green)}.dn{background:var(--red-dim);color:var(--red)}.nc{background:var(--amber-dim);color:var(--amber)}
.setting-row{display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid var(--border)}.setting-row:last-child{border-bottom:none}
.setting-lbl{font-size:13px}.setting-sub{font-size:10px;color:var(--text3);margin-top:2px}
select{background:var(--surface2);border:1px solid var(--border2);border-radius:8px;color:var(--text);font-size:12px;font-family:inherit;padding:6px 10px;cursor:pointer}
</style>
</head>
<body>
<div class="nav">
  <div><div class="nav-logo">FORGE</div><div class="nav-sub">8-Week Program</div></div>
  <div style="text-align:right"><div style="font-size:13px;font-weight:600" id="nav-wt">215 lbs</div><div style="font-size:10px;color:var(--text3)">Current weight</div></div>
</div>
<div class="tabs">
  <button class="tab-btn active" onclick="showTab('dash')">Dashboard</button>
  <button class="tab-btn" onclick="showTab('str')">Strength</button>
  <button class="tab-btn" onclick="showTab('meals')">Meals</button>
  <button class="tab-btn" onclick="showTab('groc')">Grocery</button>
  <button class="tab-btn" onclick="showTab('run')">Running</button>
  <button class="tab-btn" onclick="showTab('rehab')">Knee rehab</button>
  <button class="tab-btn" onclick="showTab('sauna')">Sauna</button>
  <button class="tab-btn" onclick="showTab('cfg')">Settings</button>
</div>

<div id="tab-dash" class="section active">
  <div class="alert ag"><strong>Day 1 complete — April 8, 2026</strong> · 42:19 · 294 active cal · Avg HR 110 bpm · 5 metcon rounds</div>
  <div class="metrics">
    <div class="metric"><div class="metric-val" style="color:var(--blue)" id="dw">215</div><div class="metric-label">lbs now</div></div>
    <div class="metric"><div class="metric-val" style="color:var(--green)" id="dl">0</div><div class="metric-label">lbs lost</div></div>
    <div class="metric"><div class="metric-val" style="color:var(--amber)" id="dp">0</div><div class="metric-label">plateaus</div></div>
  </div>
  <div class="watch-card">
    <div style="display:flex;justify-content:space-between;align-items:center">
      <div><div style="font-size:10px;font-weight:600;color:var(--blue);text-transform:uppercase;letter-spacing:0.8px">Apple Watch · Apr 8, 2026</div><div style="font-size:14px;font-weight:600;margin-top:2px">Day 1 — Upper + Arms</div><div style="font-size:10px;color:var(--text3);margin-top:1px">5:54 AM – 6:36 AM · 42:19</div></div>
      <div style="text-align:right"><div style="font-size:22px;font-weight:700;color:var(--green)">294</div><div style="font-size:9px;color:var(--text3)">ACTIVE CAL</div></div>
    </div>
    <div class="watch-stats">
      <div><div class="ws-val">382</div><div class="ws-lbl">Total cal</div></div>
      <div><div class="ws-val">110</div><div class="ws-lbl">Avg HR</div></div>
      <div><div class="ws-val">71–146</div><div class="ws-lbl">HR range</div></div>
    </div>
  </div>
  <div class="card">
    <div class="card-title">Weight log</div>
    <div class="row-input"><input type="number" id="wi" placeholder="lbs" value="215" step="0.1"><button class="btn-primary" onclick="logWt()">Log</button></div>
    <div class="prog-track"><div class="prog-fill" id="wp" style="width:0%;background:var(--blue)"></div></div>
    <div class="prog-labels"><span>215 lbs start</span><span>Goal: 195 lbs</span></div>
    <div id="wh" style="margin-top:10px"><div style="font-size:11px;color:var(--text3);text-align:center;padding:8px">No weight logs yet</div></div>
  </div>
  <div class="card">
    <div class="card-title">This week</div>
    <div style="font-size:12px;line-height:2.2;color:var(--text2)">
      <div><span style="color:var(--green);font-weight:600;margin-right:8px">Mon ✓</span>Strength — Upper + Arms <span style="font-size:10px;color:var(--green)">(Done · Apr 8)</span></div>
      <div><span style="color:var(--amber);font-weight:600;margin-right:8px">Tue</span>Run / Cardio</div>
      <div><span style="color:var(--blue);font-weight:600;margin-right:8px">Wed</span>Strength — Hinge + Metcon</div>
      <div><span style="color:var(--amber);font-weight:600;margin-right:8px">Thu</span>Run + Rehab</div>
      <div><span style="color:var(--blue);font-weight:600;margin-right:8px">Fri</span>Strength — Full Body + Metcon</div>
      <div><span style="color:var(--amber);font-weight:600;margin-right:8px">Sat</span>Long run + Sauna</div>
      <div><span style="color:var(--text3);font-weight:600;margin-right:8px">Sun</span>Rest + Sauna (lower carb day)</div>
    </div>
  </div>
  <div class="card"><div class="card-title">Plateau alerts</div><div id="psumm"><div style="font-size:11px;color:var(--text3);padding:6px 0">Log more sessions to begin tracking.</div></div></div>
</div>

<div id="tab-str" class="section">
  <div class="legend"><div class="pdot" style="width:8px;height:8px;flex-shrink:0"></div>Plateau alert — no progress in <span id="pwd" style="font-weight:700;margin:0 3px">3</span> sessions.</div>
  <div class="mlegend"><span style="font-size:10px;color:#c084fc;font-weight:600;margin-right:4px">Muscle tags:</span><span class="mtag ts">Shoulder</span><span class="mtag tt">Tricep</span><span class="mtag tb">Bicep</span><span class="mtag tc">Compound</span><span style="font-size:10px;color:var(--green);margin-left:6px">Green = Apr 8 logged</span></div>
  <div class="week-pills" id="spills"></div>
  <div id="scont"></div>
</div>

<div id="tab-meals" class="section">
  <div class="ao alert">Primal Kitchen sauces assigned every meal · Tap any day to expand</div>
  <div style="display:flex;gap:6px;margin-bottom:12px">
    <button class="btn-sm" onclick="toggleAll(true)">Expand all</button>
    <button class="btn-sm" onclick="toggleAll(false)">Collapse all</button>
  </div>
  <div id="macc"></div>
</div>

<div id="tab-groc" class="section">
  <div class="ag alert">Tap to check off · 7-day plan + Primal Kitchen list</div>
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px">
    <div style="font-size:12px;color:var(--text2)"><span id="gc">0</span> / <span id="gt">0</span> checked</div>
    <button class="btn-sm" onclick="clearGroc()">Clear all</button>
  </div>
  <div id="glist"></div>
</div>

<div id="tab-run" class="section"><div id="rcont"></div></div>

<div id="tab-rehab" class="section">
  <div class="ab alert">Complete every training day · 10–12 min · Split pre/post workout if needed</div>
  <div class="card"><div class="card-title">Daily knee protocol</div><div id="rlist"></div></div>
  <div class="card">
    <div class="card-title">Progress notes</div>
    <textarea id="rnotes" style="width:100%;background:var(--surface2);border:1px solid var(--border2);border-radius:8px;color:var(--text);font-family:inherit;font-size:12px;padding:10px;min-height:75px;resize:vertical" placeholder="Note any pain, tightness, or improvement..."></textarea>
    <button class="btn-primary" style="margin-top:8px;width:100%" onclick="saveNotes()">Save note</button>
  </div>
</div>

<div id="tab-sauna" class="section">
  <div class="aa alert">Evening sauna recommended · 8:30–9 PM · Drops core temp for deeper sleep onset</div>
  <div class="card">
    <div class="card-title">Protocol by phase</div>
    <div class="sp"><div class="sp-name">Weeks 1–2 — Acclimation</div><div class="sp-chips"><span class="sp-chip">110–115°F</span><span class="sp-chip">10–15 min</span><span class="sp-chip">3–4x/wk</span></div><div style="font-size:10px;color:var(--text3);margin-top:4px">Exit if dizzy. Build slowly.</div></div>
    <div class="sp"><div class="sp-name">Weeks 3–4 — Building</div><div class="sp-chips"><span class="sp-chip">120–130°F</span><span class="sp-chip">15–20 min</span><span class="sp-chip">4–5x/wk</span></div></div>
    <div class="sp"><div class="sp-name">Weeks 5–6 — Therapeutic</div><div class="sp-chips"><span class="sp-chip">130–140°F</span><span class="sp-chip">20–30 min</span><span class="sp-chip">5–6x/wk</span></div></div>
    <div class="sp"><div class="sp-name">Weeks 7–8 — Full protocol</div><div class="sp-chips"><span class="sp-chip">130–150°F</span><span class="sp-chip">25–35 min</span><span class="sp-chip">5–7x/wk</span></div></div>
  </div>
  <div class="card">
    <div class="card-title">Sauna timer</div>
